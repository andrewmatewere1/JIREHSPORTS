# ============================================================
# JIREH SPORTS MANAGEMENT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# --- SERVER ---
PORT=5000
NODE_ENV=development

# --- DATABASE (PostgreSQL) ---
# Get these from Supabase, Railway, or your own PostgreSQL server
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jireh_sports
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# If using a connection string instead (e.g. from Railway/Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/jireh_sports

# --- JWT SECRET (make this long and random) ---
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# --- EMAIL (Gmail example — see README for SendGrid alternative) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Jireh Sports Management <noreply@jirehsports.com>

# --- ADMIN ---
ADMIN_PASSWORD=change_this_strong_password

# --- FRONTEND URL (for CORS) ---
FRONTEND_URL=http://localhost:5173
